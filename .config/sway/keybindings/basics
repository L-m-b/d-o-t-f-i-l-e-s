# Basics
bindsym $mod+Return exec $term
bindsym $mod+shift+q kill -s 3
bindsym $mod+d exec $menu
bindsym $mod+Shift+r reload
floating_modifier $mod normal

# Lock Screen
bindsym $mod+l exec --no-startup-id swaylock

# Power Menu
bindsym $mod+p exec --no-startup-id kitty --class="floatp" aurevoir -c ~/.config/aurevoir/sway.toml

# Switch to prev/next workspace
bindsym $mod+slash workspace next
bindsym $mod+period workspace prev

# Audio controls
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%

# Brightness controls
bindsym XF86MonBrightnessDown exec brightnessctl set 1%-
bindsym XF86MonBrightnessUp exec brightnessctl set +1%

# Microphone mute/unmute
#bindsym F9 exec amixer set Capture toggle

# Screenshots
bindsym Print exec grimshot save screen ~/Pictures/Screenshots/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
bindsym Shift+Print exec grimshot save active ~/Pictures/Screenshots/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
bindsym ctrl+Shift+Print exec grimshot save area ~/Pictures/Screenshots/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
